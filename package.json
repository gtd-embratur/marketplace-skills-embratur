{
  "name": "@embratur/marketplace-skills-monorepo",
  "version": "0.0.0",
  "author": "Embratur",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "Marketplace de Skills da Embratur para agentes de IA",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:skill": "nx g @embratur/skill-plugin:skill",
    "generate:registry": "nx run @embratur/skills-catalog:generate-registry",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "nx release",
    "release:dry": "nx release --dry-run",
    "validate": "npx tsx tools/validate-skills.ts --batch packages/skills-catalog/skills",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' nx run-many -t test"
  },
  "devDependencies": {
    "@nx/devkit": "^22.6.3",
    "@nx/esbuild": "^22.6.3",
    "@nx/eslint": "^22.6.3",
    "@nx/eslint-plugin": "^22.6.3",
    "@nx/jest": "^22.7.0",
    "@nx/js": "^22.6.3",
    "@nx/next": "^22.7.5",
    "@nx/node": "^22.6.3",
    "@nx/plugin": "^22.6.3",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "1.15.21",
    "@swc/helpers": "~0.5.20",
    "@types/jest": "^30.0.0",
    "@types/node": "^22",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "jest-util": "^30.3.0",
    "jsonc-eslint-parser": "^2.4.2",
    "nx": "^22.6.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "yaml": "^2.8.3"
  },
  "nx": {
    "includedScripts": []
  }
}
